{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Chat session metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "bot"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Metadata for each conversation session"
    },
    "/users/{userId}/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
