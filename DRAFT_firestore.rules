rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'lastActive']) &&
             data.keys().size() <= 4 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.lastActive == request.time;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['id', 'title', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.userId == request.auth.uid &&
             (request.method == 'create' ? data.createdAt == request.time : true) &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.id is string && data.id.size() <= 128 &&
             data.role in ['user', 'bot'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time;
    }

    // --- Collections ---

    // 1. Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastActive']);
    }

    // 2. Conversations
    match /users/{userId}/conversations/{convId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(convId);
      
      allow create: if isOwner(userId) && 
                      isValidId(convId) && 
                      isValidConversation(incoming());
      
      allow update: if isOwner(userId) && 
                      isValidId(convId) && 
                      isValidConversation(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().id == existing().id &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
      
      allow delete: if isOwner(userId) && isValidId(convId);

      // 3. Messages
      match /messages/{msgId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(msgId);
        
        allow create: if isOwner(userId) && 
                        isValidId(msgId) && 
                        isValidMessage(incoming()) &&
                        exists(/databases/$(database)/documents/users/$(userId)/conversations/$(convId));
        
        // Messages are immutable in this flow
        allow update: if false;
        allow delete: if isOwner(userId) && isValidId(msgId);
      }
    }
  }
}
